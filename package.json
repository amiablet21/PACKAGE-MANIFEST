{
  "name": "manifest",
  "version": "1.0.0",
  "description": "Manifest — desktop app for creating UPS and FedEx pickup manifests",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run vite\" \"wait-on http://localhost:5173 && npx --no electron .\"",
    "vite": "vite",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.manifest.app",
    "productName": "Manifest",
    "win": {
      "icon": "public/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Manifest"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
